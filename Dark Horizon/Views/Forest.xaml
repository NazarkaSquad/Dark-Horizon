<UserControl x:Class="Dark_Horizon.Views.Forest"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:Dark_Horizon.Views"
             mc:Ignorable="d"
             RenderOptions.BitmapScalingMode="NearestNeighbor"
             Width="1920" Height="1080">

    <Grid>
        <Image Source="pack://application:,,,/Assets/Images/Backgrounds/Forest.png"
               Width="1920" Height="1080"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>

        <Canvas>
            <Button x:Name="BtnToOutskirt"
                    Width="70" Height="115"
                    Canvas.Left="925" Canvas.Top="45"
                    Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                    Click="BtnToOutskirt_Click" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Image Source="pack://application:,,,/Assets/Images/UI/ArrowU.png"
                               Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="BtnToLeftLoc"
                    Width="115" Height="70"
                    Canvas.Left="43" Canvas.Top="505"
                    Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                    Click="BtnToSwamp_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Image Source="pack://application:,,,/Assets/Images/UI/ArrowL.png"
                               Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <views:HudPanel x:Name="Hud"
                            Canvas.Left="0" Canvas.Top="820"
                            CurrentLocationKey="Forest"/>
        </Canvas>
    </Grid>
</UserControl>
