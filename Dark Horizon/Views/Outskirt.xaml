<UserControl x:Class="Dark_Horizon.Views.Outskirt"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:Dark_Horizon.Views"
             mc:Ignorable="d"
             
             Width="1920" Height="1080">

    <Grid>
        <Canvas>

            <Image Source="pack://application:,,,/Assets/Images/Backgrounds/Outskirt.png" 
       Width="1920" Height="1080" 
       Stretch="UniformToFill" 
       Canvas.Left="0" Canvas.Top="0"/>

            <Button x:Name="BtnToCity" 
                    Width="70" Height="115" 
                    Canvas.Left="934" Canvas.Top="70"
                Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                    Click="BtnToCity_Click" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image Source="pack://application:,,,/Assets/Images/UI/ArrowU.png" 
               Stretch="Fill" 
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>


            <Button x:Name="BtnToBottomLoc" 
                    Width="70" Height="115" 
                    Canvas.Left="934" Canvas.Top="915" 
                    Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                    Click="BtnToBottomLoc_Click" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image Source="pack://application:,,,/Assets/Images/UI/ArrowD.png" 
                                   Stretch="Fill" 
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" Margin="0,-10,0,10"/>
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <views:HudPanel x:Name="Hud"
                            Canvas.Left="0" Canvas.Top="820"
                            CurrentLocationKey="Forest"/>

        </Canvas>
    </Grid>
</UserControl>