<UserControl x:Class="Dark_Horizon.Views.Slotselectscreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Dark_Horizon.Views"
             mc:Ignorable="d"
             RenderOptions.BitmapScalingMode="NearestNeighbor"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <UserControl.Resources>
        <FontFamily x:Key="PixelFont">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>
    </UserControl.Resources>

    <Canvas ClipToBounds="True">


        <Border Width="620" Height="620"
                Canvas.Left="650" Canvas.Top="230">
            <Grid>
                <Image Source="pack://application:,,,/Assets/Images/UI/SlotSelect.png" Stretch="UniformToFill"/>

                <StackPanel Margin="30,30">

                    <TextBlock Text="ОБЕРІТЬ СЛОТ"
                           FontFamily="{StaticResource PixelFont}"
                           FontSize="31"
                           Foreground="white"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,10"
                           Visibility="Visible"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           TextOptions.TextFormattingMode="Display"
                           TextOptions.TextHintingMode="Fixed" />


                    <local:Saveslotpanel x:Name="Slot1" Margin="0,0,0,16"/>
                    <local:Saveslotpanel x:Name="Slot2" Margin="0,0,0,16"/>
                    <local:Saveslotpanel x:Name="Slot3" Margin="0,0,0,30"/>

                    <Button x:Name="BtnBack"
                        Width="180" Height="44"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnBack_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="ButtonGrid">
                                    <Image Source="pack://application:,,,/Assets/Images/UI/Button.png" Stretch="Fill"/>

                                    <TextBlock Text="← НАЗАД"
                                           FontFamily="{StaticResource PixelFont}"
                                           FontSize="16"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,3"
                                           TextOptions.TextFormattingMode="Display"
                                           TextOptions.TextRenderingMode="Aliased"/>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ButtonGrid" Property="Opacity" Value="0.9"/>
                                        <Setter Property="TextBlock.Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ButtonGrid" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

    </Canvas>
</UserControl>