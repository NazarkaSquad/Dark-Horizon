<UserControl x:Class="Dark_Horizon.Views.Swamp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:Dark_Horizon.Views"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920">

    <Grid>
        <Image Source="pack://application:,,,/Assets/Images/Backgrounds/Swamp.png"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>

        <Canvas>
            <!-- Стрілка праворуч — на Ліс -->
            <Button x:Name="BtnToForest"
                    Width="115" Height="70"
                    Canvas.Left="1774" Canvas.Top="505"
                    Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                    Click="BtnToForest_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Image Source="pack://application:,,,/Assets/Images/UI/ArrowR.png"
                               Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- HUD-панель (зліва знизу) -->
            <views:HudPanel x:Name="Hud"
                            Canvas.Left="0" Canvas.Top="820"
                            CurrentLocationKey="Swamp"/>
        </Canvas>
    </Grid>
</UserControl>
