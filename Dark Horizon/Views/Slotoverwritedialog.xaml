<Window x:Class="Dark_Horizon.SlotOverwriteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" 
        Width="460" Height="280"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        RenderOptions.BitmapScalingMode="NearestNeighbor"
        AllowsTransparency="True">

    <Window.Resources>
        <FontFamily x:Key="PixelFont">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>

        <Style x:Key="ImageButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image Source="/Assets/Images/UI/Button.png" Stretch="Fill"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource PixelFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Image Source="/Assets/Images/UI/SlotOver.png" Stretch="UniformToFill"/>

        <Border BorderBrush="Transparent" BorderThickness="0" Padding="30,24">
            <StackPanel>
                <TextBlock Text="СЛОТ ЗАЙНЯТИЙ"
                           FontFamily="{StaticResource PixelFont}"
                           FontSize="22"
                           Foreground="white"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>


                <TextBlock x:Name="TxtInfo" FontFamily="{StaticResource PixelFont}" FontSize="13" Foreground="White" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock x:Name="TxtDate" FontFamily="{StaticResource PixelFont}" FontSize="11" Foreground="white" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Що бажаєш зробити?" FontFamily="{StaticResource PixelFont}" FontSize="14" Foreground="white" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnLoad" Content="Завантажити" Width="160" Height="40" Margin="0,0,16,0"
                            Style="{StaticResource ImageButtonStyle}" FontSize="13" Click="BtnLoad_Click"/>

                    <Button x:Name="BtnNew" Content="Нова гра" Width="160" Height="40"
                            Style="{StaticResource ImageButtonStyle}" FontSize="13" Click="BtnNew_Click"/>
                </StackPanel>

                <Button x:Name="BtnCancel" Content="Скасувати" Width="140" Height="40" Margin="0,10,0,0"
                        Style="{StaticResource ImageButtonStyle}" FontSize="13" Foreground="white" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>