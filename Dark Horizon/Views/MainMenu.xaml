<UserControl x:Class="Dark_Horizon.Views.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:Dark_Horizon.Views"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <Canvas ClipToBounds="True">
        <Canvas.Resources>
            <Style TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="Transparent"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Canvas.Resources>

        <Image Source="pack://application:,,,/Assets/Images/Backgrounds/Menu art.png" 
       Width="1920" Height="1080" 
       Stretch="UniformToFill" 
       RenderOptions.BitmapScalingMode="NearestNeighbor"
       Canvas.Left="0" Canvas.Top="0"/>
        
        <Canvas x:Name="MainMenuContent" Width="1920" Height="1080" Canvas.Left="0" Canvas.Top="0">

        <Image x:Name="imgLogo" 
       Source="pack://application:,,,/Assets/Fonts/Logo.png" 
       Width="600" Height="200" 
       Canvas.Left="25" Canvas.Top="170" 
       Stretch="Uniform"
       RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <Button x:Name="BtnPlay" 
                Width="369" Height="81" 
                Canvas.Left="25" Canvas.Top="280" 
                Click="BtnPlay_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Image x:Name="imgPlay" 
                           Source="pack://application:,,,/Assets/Images/UI/NewGameButton.png"
                           Cursor="Hand"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="imgPlay" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="imgPlay" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button x:Name="BtnLoad"  
                Width="369" Height="81" 
                Canvas.Left="25" Canvas.Top="380" 
                Click="BtnLoad_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Image x:Name="imgLoud" 
                           Source="pack://application:,,,/Assets/Images/UI/LoudButton.png"
                           Cursor="Hand"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="imgLoud" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="imgLoud" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button x:Name="BtnSettings"  
                Width="369" Height="81" 
                Canvas.Left="25" Canvas.Top="480" 
                Click="BtnSettings_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Image x:Name="imgSettings" 
                           Source="pack://application:,,,/Assets/Images/UI/SettingsButton.png"
                           Cursor="Hand"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="imgSettings" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="imgSettings" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button x:Name="BtnExit" 
                Width="369" Height="81" 
                Canvas.Left="25" Canvas.Top="580" 
                Click="BtnExit_Click" HorizontalAlignment="Center" VerticalAlignment="Top" >
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Image x:Name="imgExit" 
                   Source="pack://application:,,,/Assets/Images/UI/ExitButton.png"
                   Cursor="Hand"
                   Stretch="Fill"
                    RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="imgExit" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="imgExit" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
            <Viewbox x:Name="SettingsContainer"
                 Width="525" Height="750" 
                 Canvas.Left="1920" Canvas.Top="165"
                 Visibility="Collapsed">
                <views:Settings x:Name="SettingsPanel" />
            
        </Viewbox>
    </Canvas>
        <Canvas x:Name="SlotSelectContainer" Width="1920" Height="1080" Canvas.Left="1920" Canvas.Top="0">
            <views:Slotselectscreen x:Name="SlotSelectPanel" Width="1920" Height="1080"/>
        </Canvas>

        <Canvas x:Name="CharacterCreateContainer" Width="1920" Height="1080" Canvas.Left="1920" Canvas.Top="0">
            <views:Charactercreatescreen x:Name="CharacterCreatePanel" Width="1920" Height="1080"/>
        </Canvas>

    </Canvas>
</UserControl>