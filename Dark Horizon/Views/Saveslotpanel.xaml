<UserControl x:Class="Dark_Horizon.Views.Saveslotpanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             RenderOptions.BitmapScalingMode="NearestNeighbor"
             Width="500" Height="110">
    <UserControl.Resources>
        <FontFamily x:Key="PixelFont">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>
    </UserControl.Resources>

    <Grid>
        <Image Source="pack://application:,,,/Assets/Images/UI/Slot.png" Stretch="Fill"/>

        <Grid Margin="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TxtSlotTitle"
                       Grid.Row="0" Grid.Column="0"
                       Text="СЛОТ 1"
                       FontFamily="{StaticResource PixelFont}"
                       FontSize="16"
                       Foreground="White"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       TextOptions.TextFormattingMode="Display"
                       TextOptions.TextHintingMode="Fixed"/>

            <TextBlock x:Name="TxtCharInfo"
                       Grid.Row="1" Grid.Column="0"
                       Text="— Порожньо —"
                       FontFamily="{StaticResource PixelFont}"
                       FontSize="14"
                       Foreground="White"/>

            <TextBlock x:Name="TxtSaveDate"
                       Grid.Row="2" Grid.Column="0"
                       Text=""
                       FontFamily="{StaticResource PixelFont}"
                       FontSize="14"
                       Foreground="White"
                       Margin="0,4,0,0"/>

            <Button x:Name="BtnSelect"
                    Grid.Row="0" Grid.RowSpan="3" Height="58"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnSelect_Click" Margin="349,12,13,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <TextBlock x:Name="BtnText"
                                       Text="ОБРАТИ"
                                       FontFamily="{StaticResource PixelFont}"
                                       FontSize="15"
                                       Foreground="White" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnText" Property="Foreground" Value="gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</UserControl>