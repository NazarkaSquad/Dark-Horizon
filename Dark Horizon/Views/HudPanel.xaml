<UserControl x:Class="Dark_Horizon.Views.HudPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             RenderOptions.BitmapScalingMode="NearestNeighbor"
             Width="260" Height="260">

    <UserControl.Resources>
        <FontFamily x:Key="PF">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>

        <Style x:Key="HudBtn" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/Button.png" Stretch="Fill"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="{StaticResource PF}"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="25,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="MenuPanel"
                                         Storyboard.TargetProperty="Opacity"
                                         To="1" Duration="0:0:0.2"/>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="MenuPanel"
                                                       Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation Storyboard.TargetName="HudIcon"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="MenuPanel"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0" Duration="0:0:0.2"/>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="MenuPanel"
                                                       Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation Storyboard.TargetName="HudIcon"
                                         Storyboard.TargetProperty="Opacity"
                                         To="1" Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Border x:Name="HudIcon"
                Margin="10,0,0,10"
                Width="80" Height="80"
                HorizontalAlignment="Left" VerticalAlignment="Bottom">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/HudIcon.png" Stretch="Fill"/>
            </Border.Background>
        </Border>

        <Border x:Name="MenuPanel"
                Width="240" Height="240"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Visibility="Collapsed" Opacity="0">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/MenuPanel.png" Stretch="Fill"/>
            </Border.Background>

            <StackPanel Margin="12,16,12,12">
                <Button x:Name="BtnQuests"
                        Content="📜  КВЕСТИ"
                        Height="48" Margin="0,4,0,0"
                        Style="{StaticResource HudBtn}"
                        Click="BtnQuests_Click"/>
                <Button x:Name="BtnMap"
                        Content="🗺  МАПА"
                        Height="48" Margin="0,4,0,0"
                        Style="{StaticResource HudBtn}"
                        Click="BtnMap_Click"/>
                <Button x:Name="BtnInventory"
                        Content="🎒  ІНВЕНТАР"
                        Height="48" Margin="0,4,0,0"
                        Style="{StaticResource HudBtn}"
                        Click="BtnInventory_Click"/>
                <Button x:Name="BtnAdventure"
                        Content="⚔  ПОШУК ПРИГОД"
                        Height="48" Margin="0,4,0,0"
                        Style="{StaticResource HudBtn}"
                        Click="BtnAdventure_Click"/>
            </StackPanel>
        </Border>

        <Popup x:Name="ToastPopup"
               PlacementTarget="{Binding ElementName=MenuPanel}"
               Placement="Top"
               VerticalOffset="-5" 
               HorizontalOffset="10"
               AllowsTransparency="True"
               IsOpen="False">
            <Border Background="#353535" BorderBrush="#292929" BorderThickness="2"
                    Padding="14,8" MaxWidth="460">
                <TextBlock x:Name="TxtToast"
                           FontFamily="{StaticResource PF}" FontSize="16"
                           Foreground="White" TextWrapping="Wrap"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>