<UserControl x:Class="Dark_Horizon.Views.Charactercreatescreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             RenderOptions.BitmapScalingMode="NearestNeighbor">

    <UserControl.Resources>
        <FontFamily x:Key="PixelFont">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>

        <Style x:Key="SelectBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="BtnGrid" Opacity="0.6">
                            <Image Source="pack://application:,,,/Assets/Images/UI/Button.png" Stretch="Fill"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,3">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource PixelFont}"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnGrid" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnGrid" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectBtnActive" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="BtnGrid" Opacity="1.0">
                            <Image Source="pack://application:,,,/Assets/Images/UI/Button.png" Stretch="Fill"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,3">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource PixelFont}"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Canvas ClipToBounds="True">
        <TextBlock Text="ВИГЛЯД"
                   FontFamily="{StaticResource PixelFont}"
                   FontSize="16" Foreground="White"
                   Canvas.Left="290" Canvas.Top="160"/>

        <Border Width="360" Height="500" Canvas.Left="180" Canvas.Top="185" BorderThickness="0">
            <Grid>
                <Image Source="pack://application:,,,/Assets/Images/UI/HeroBackground.png" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                <Canvas x:Name="CharacterCanvas" Width="320" Height="460" Margin="20,20,20,0">
                    <Image x:Name="PlayerSprite" Width="320" Height="460" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                </Canvas>
            </Grid>
        </Border>

        <TextBlock Text="ІМ'Я ПЕРСОНАЖА" FontFamily="{StaticResource PixelFont}" FontSize="14" Foreground="White" Canvas.Left="180" Canvas.Top="110"/>

        <Border Width="360" Height="48" Canvas.Left="180" Canvas.Top="124" BorderThickness="0">
            <Grid>
                <Image Source="pack://application:,,,/Assets/Images/UI/Name.png" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <TextBox x:Name="TxtPlayerName" Text="Герой" FontFamily="{StaticResource PixelFont}" FontSize="20" Foreground="White" Background="Transparent" BorderThickness="0" Padding="14,10" CaretBrush="White" MaxLength="20"/>
            </Grid>
        </Border>

        <Border Width="880" Height="650" Canvas.Left="620" Canvas.Top="115" BorderThickness="0">
            <Grid>
                <Image Source="pack://application:,,,/Assets/Images/UI/HeroCreateBackground.png" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <StackPanel Margin="36,28">
                    <TextBlock Text="СТВОРЕННЯ ПЕРСОНАЖА" FontFamily="{StaticResource PixelFont}" FontSize="30" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="РАСА" FontFamily="{StaticResource PixelFont}" FontSize="17" Foreground="White" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="BtnRaceHuman" Content="⚔ Людина" Style="{StaticResource SelectBtnActive}" Width="180" Click="Race_Click" Tag="Human"/>
                        <Button x:Name="BtnRaceOrc" Content="💪 Орк" Style="{StaticResource SelectBtn}" Width="180" Click="Race_Click" Tag="Orc"/>
                        <Button x:Name="BtnRaceElf" Content="🌿 Ельф" Style="{StaticResource SelectBtn}" Width="180" Click="Race_Click" Tag="Elf"/>
                    </StackPanel>

                    <Border Width="770" HorizontalAlignment="Left" BorderThickness="0" Padding="16,10" Margin="4,0,0,24">
                        <Border.Background>
                            <ImageBrush ImageSource="/Assets/Images/UI/TextTipe.png" 
                    Stretch="Fill" 
                    RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border.Background>

                        <TextBlock x:Name="TxtRaceDesc" FontFamily="{StaticResource PixelFont}" FontSize="17" Foreground="White" 
               TextWrapping="Wrap" 
               Text="Збалансована раса без яскравих слабкостей. Отримує на 10% більше золото з мобів."/>
                    </Border>

                    <TextBlock Text="СТВОРЕННЯ СТАТІ" FontFamily="{StaticResource PixelFont}" FontSize="17" Foreground="White" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Button x:Name="BtnGenderMale" Content="♂ Чоловік" Style="{StaticResource SelectBtnActive}" Width="180" Click="Gender_Click" Tag="Male"/>
                        <Button x:Name="BtnGenderFemale" Content="♀ Жінка" Style="{StaticResource SelectBtn}" Width="180" Click="Gender_Click" Tag="Female"/>
                    </StackPanel>

                    <TextBlock Text="КЛАС" FontFamily="{StaticResource PixelFont}" FontSize="17" Foreground="White" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button x:Name="BtnClassWarrior" Content="🛡 Воїн" Style="{StaticResource SelectBtnActive}" Width="190" Click="Class_Click" Tag="Warrior"/>
                        <Button x:Name="BtnClassRogue" Content="🗡 Розбійник" Style="{StaticResource SelectBtn}" Width="190" Click="Class_Click" Tag="Rogue"/>
                        <Button x:Name="BtnClassMage" Content="✨ Маг" Style="{StaticResource SelectBtn}" Width="190" Click="Class_Click" Tag="Mage"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button x:Name="BtnClassPaladin" Content="☀ Паладін" Style="{StaticResource SelectBtn}" Width="190" Click="Class_Click" Tag="Paladin"/>
                        <Button x:Name="BtnClassArcher" Content="🏹 Лучник" Style="{StaticResource SelectBtn}" Width="190" Click="Class_Click" Tag="Archer"/>
                        <Button x:Name="BtnClassNecro" Content="💀 Некромант" Style="{StaticResource SelectBtn}" Width="190" Click="Class_Click" Tag="Necromancer"/>
                    </StackPanel>

                    <Border Width="770" HorizontalAlignment="Left" BorderThickness="0" Padding="16,10" Margin="4,0,0,16">
                        <Border.Background>
                            <ImageBrush ImageSource="/Assets/Images/UI/TextTipe.png" 
                    Stretch="Fill" 
                    RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border.Background>
                        <TextBlock x:Name="TxtClassDesc" FontFamily="{StaticResource PixelFont}" FontSize="17" Foreground="White" TextWrapping="Wrap"/>
                    </Border>

                    <UniformGrid Columns="3" Width="500" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="HP" FontFamily="{StaticResource PixelFont}" FontSize="13" Foreground="#FF6B6B" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtHP" Text="150" FontFamily="{StaticResource PixelFont}" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="АТАКА" FontFamily="{StaticResource PixelFont}" FontSize="13" Foreground="#FFD700" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtAtk" Text="17" FontFamily="{StaticResource PixelFont}" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="ЗАХИСТ" FontFamily="{StaticResource PixelFont}" FontSize="13" Foreground="#87CEEB" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtDef" Text="6" FontFamily="{StaticResource PixelFont}" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnBack" Width="320" Height="58" Margin="0,20,20,20" Cursor="Hand" Click="BtnBack_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid x:Name="ButtonGrid">
                                        <Image Source="pack://application:,,,/Assets/Images/UI/Button.png" Stretch="Fill"/>
                                        <TextBlock Text="← НАЗАД" FontFamily="{StaticResource PixelFont}" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnStartGame" Width="320" Height="58" Cursor="Hand" Click="BtnStartGame_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid x:Name="StartGrid">
                                        <Image Source="pack://application:,,,/Assets/Images/UI/Button.png" Stretch="Fill"/>
                                        <TextBlock Text="ПОЧАТИ ГРУ" FontFamily="{StaticResource PixelFont}" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Canvas>
</UserControl>