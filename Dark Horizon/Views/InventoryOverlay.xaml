<UserControl x:Class="Dark_Horizon.Views.InventoryOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             RenderOptions.BitmapScalingMode="NearestNeighbor"
             Width="1920" Height="1080">

    <UserControl.Resources>
        <FontFamily x:Key="PF">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>

        <Style x:Key="FilterBtn" TargetType="RadioButton">
            <Setter Property="GroupName" Value="InvFilter"/>
            <Setter Property="FontFamily" Value="{StaticResource PF}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" BorderThickness="0">
                            <Border.Background>
                                <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/Button2.png" Stretch="Fill"/>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="1.0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource PF}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" BorderThickness="0">
                            <Border.Background>
                                <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/Button.png" Stretch="Fill"/>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Rectangle Fill="#CC000000" MouseDown="Backdrop_MouseDown"/>

        <Border Width="1500" Height="880" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="0">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/MainPanel.png" Stretch="Fill"/>
            </Border.Background>

            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="ІНВЕНТАР" FontFamily="{StaticResource PF}" FontSize="29"
                               Foreground="White" HorizontalAlignment="Left"/>

                    <Border Background="Transparent" BorderThickness="0"
                            Padding="14,6" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Images/Items/Gold.png" Width="22" Height="22" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtGold" Text="0" FontFamily="{StaticResource PF}"
                                       FontSize="18" Foreground="#FFD700" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="BtnClose" Width="40" Height="40" HorizontalAlignment="Right" Cursor="Hand" Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" BorderThickness="0">
                                    <Border.Background>
                                        <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/Close.png" Stretch="Fill"/>
                                    </Border.Background>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderThickness="0">
                        <Border.Background>
                            <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/CharBg.png" Stretch="Fill"/>
                        </Border.Background>

                        <StackPanel Margin="20" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtPlayerName" Text="Герой" FontFamily="{StaticResource PF}"
                                       FontSize="20" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="26" Height="260"
                                        Background="#2A1010" BorderBrush="#5A4A20" BorderThickness="2"
                                        VerticalAlignment="Bottom" Margin="10,0,10,0">
                                    <Grid VerticalAlignment="Bottom">
                                        <Rectangle x:Name="HpBarFill" Fill="#C0392B" VerticalAlignment="Bottom" Height="260"/>
                                    </Grid>
                                </Border>

                                <Image x:Name="ImgPlayerCharacter" 
                                       Grid.Column="1" 
                                       Width="200" Height="260" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Stretch="Uniform"/>
                            </Grid>

                            <Border BorderThickness="0" Height="46" Margin="0,20,0,0">
                                <Border.Background>
                                    <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/ESlot.png" Stretch="Fill"/>
                                </Border.Background>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="⚔" FontSize="20" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    <Grid Grid.Column="1" Margin="20,0">
                                        <TextBlock x:Name="TxtWeaponSlot" Text="Не одягнено" FontFamily="{StaticResource PF}"
                       FontSize="14" Foreground="White" TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <Button x:Name="BtnUnequipWeapon" Content="✕" Width="26" Height="26" Padding="0"
                    Style="{StaticResource ActionBtn}"
                    HorizontalAlignment="Right" Click="BtnUnequipWeapon_Click" Visibility="Collapsed"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border BorderThickness="0" Height="46" Margin="0,10,0,0">
                                <Border.Background>
                                    <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/ESlot.png" Stretch="Fill"/>
                                </Border.Background>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="🛡" FontSize="18" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    <Grid Grid.Column="1" Margin="20,0">
                                        <TextBlock x:Name="TxtArmorSlot" Text="Не одягнено" FontFamily="{StaticResource PF}"
                       FontSize="14" Foreground="White" TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <Button x:Name="BtnUnequipArmor" Content="✕" Width="26" Height="26" Padding="0"
                    Style="{StaticResource ActionBtn}"
                    HorizontalAlignment="Right" Click="BtnUnequipArmor_Click" Visibility="Collapsed"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="TxtPlayerLevel" Text="РІВЕНЬ 1" FontFamily="{StaticResource PF}"
                                       FontSize="18" Foreground="White" HorizontalAlignment="Center" Margin="0,18,0,0"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <TextBlock x:Name="TxtTotalAttack" Text="⚔ 15" FontFamily="{StaticResource PF}"
                                           FontSize="14" Foreground="White" Margin="0,0,16,0"/>
                                <TextBlock x:Name="TxtTotalDefense" Text="🛡 5" FontFamily="{StaticResource PF}"
                                           FontSize="14" Foreground="White" Margin="0,0,16,0"/>
                                <TextBlock x:Name="TxtTotalHealth" Text="♥ 100/100" FontFamily="{StaticResource PF}"
                                           FontSize="14" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton x:Name="FilterAll"     Content="УСІ"   Style="{StaticResource FilterBtn}" IsChecked="True" Checked="Filter_Changed" Margin="0,0,8,0"/>
                            <RadioButton x:Name="FilterWeapon"   Content="ЗБРОЯ" Style="{StaticResource FilterBtn}" Checked="Filter_Changed" Margin="0,0,8,0"/>
                            <RadioButton x:Name="FilterArmor"    Content="БРОНЯ" Style="{StaticResource FilterBtn}" Checked="Filter_Changed" Margin="0,0,8,0"/>
                            <RadioButton x:Name="FilterFood"     Content="ЇЖА"   Style="{StaticResource FilterBtn}" Checked="Filter_Changed"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderThickness="0">
                            <Border.Background>
                                <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/ItemsBg.png" Stretch="Fill"/>
                            </Border.Background>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                <ItemsControl x:Name="ItemsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1A1208" BorderBrush="#3A3020" BorderThickness="1"
                                                    Margin="8" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="56"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" Width="48" Height="48"
                                                            Background="#2A2410" BorderBrush="#5A4A20" BorderThickness="1">
                                                        <Image Source="{Binding IconPath}" Stretch="Uniform" Margin="6"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource PF}"
                                                                   FontSize="16" Foreground="White"/>
                                                        <TextBlock Text="{Binding Description}" FontFamily="{StaticResource PF}"
                                                                   FontSize="12" Foreground="White" TextWrapping="Wrap" Margin="0,2,0,0" Opacity="0.7"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2" Text="{Binding StatText}"
                                                               FontFamily="{StaticResource PF}" FontSize="14"
                                                               Foreground="White" VerticalAlignment="Center"/>

                                                    <Button Grid.Column="3" Content="{Binding ActionLabel}"
                                                            Style="{StaticResource ActionBtn}"
                                                            IsEnabled="{Binding CanAct}"
                                                            Click="BtnRowAction_Click"
                                                            VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>