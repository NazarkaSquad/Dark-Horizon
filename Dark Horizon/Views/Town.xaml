<UserControl x:Class="Dark_Horizon.Views.Town"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:Dark_Horizon.Views"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920">

    <Canvas Background="#1A1A1A">
        <Canvas.Resources>
            <Style TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="Transparent"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Canvas.Resources>

        <!-- Фон -->
        <Image Source="pack://application:,,,/Assets/Images/Backgrounds/Town.png"
               Width="1920" Height="1080" Stretch="UniformToFill"
               Canvas.Left="0" Canvas.Top="0"/>

        <!-- Будівлі -->
        <Button x:Name="BtnTavern"    Width="350" Height="400" Canvas.Left="134"  Canvas.Top="45"  Click="BtnTavern_Click"/>
        <Button x:Name="BtnForge"     Width="350" Height="400" Canvas.Left="1408" Canvas.Top="96"  Click="BtnForge_Click"/>
        <Button x:Name="BtnAlchemist" Width="450" Height="400" Canvas.Left="1378" Canvas.Top="604" Click="BtnAlchemist_Click"/>

        <!-- Вихід -->
        <Button x:Name="BtnLeaveTown" Width="70" Height="115"
                Canvas.Left="925" Canvas.Top="889"
                Background="Transparent" BorderThickness="0" Cursor="Hand"
                Click="BtnLeaveTown_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid><Image Source="pack://application:,,,/Assets/Images/UI/ArrowD.png"
                                 Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/></Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- HUD (мирна зона — Пошук пригод покаже помилку) -->
        <views:HudPanel x:Name="Hud"
                        Canvas.Left="0" Canvas.Top="820"
                        CurrentLocationKey="Town"/>
    </Canvas>
</UserControl>
