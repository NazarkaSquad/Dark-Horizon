<UserControl x:Class="Dark_Horizon.Views.Settings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Dark_Horizon.Views"
             xmlns:views="clr-namespace:Dark_Horizon"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Width="350" Height="500">

    <UserControl.Resources>
        <FontFamily x:Key="PixelFont">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>
    </UserControl.Resources>

    <Border Background="Transparent">
        <Canvas Width="350" Height="500">

            <Image Source="pack://application:,,,/Assets/Images/UI/Settings.png"
                   Width="350" Height="500"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   Canvas.Left="0" Canvas.Top="0"/>

            <ToggleButton x:Name="BtnScreenModeTrigger"
                          Width="130" Height="24"
                          Canvas.Left="160" Canvas.Top="62"
                          Cursor="Hand"
                          Click="BtnScreenModeTrigger_Click">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Image Source="pack://application:,,,/Assets/Images/UI/ComboBox.png"
                                   Width="130" Height="24"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Grid>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>

            <TextBlock x:Name="TxtCurrentMode"
                       Text="Повноекранний"
                       Canvas.Left="180" Canvas.Top="69"
                       Foreground="White" FontSize="12" FontFamily="{StaticResource PixelFont}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False"/>

            <Border x:Name="ComboDropdownPanel"
                    Width="128" Height="30"
                    Canvas.Left="161" Canvas.Top="85"
                    Visibility="Collapsed"
                    Panel.ZIndex="99">
                <Grid>
                    <Image Source="pack://application:,,,/Assets/Images/UI/Dropdown.png"
                           Width="128" Height="30"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <StackPanel>
                        <Button x:Name="BtnSelectFullscreen" Height="15"
                                Background="Transparent" BorderThickness="0"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
                                Cursor="Hand" Click="BtnSelectFullscreen_Click">
                            <TextBlock Text="Повноекранний" Foreground="White"
                                       FontFamily="{StaticResource PixelFont}" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnSelectWindowed" Height="15"
                                Background="Transparent" BorderThickness="0"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
                                Cursor="Hand" Click="BtnSelectWindowed_Click">
                            <TextBlock Text="Віконний" Foreground="White"
                                       FontFamily="{StaticResource PixelFont}" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="Автозбереження"
                       Canvas.Left="27" Canvas.Top="140"
                       Foreground="White" FontSize="13"
                       FontFamily="{StaticResource PixelFont}"/>

            <TextBlock x:Name="TxtAutoSaveValue"
                       Canvas.Left="240" Canvas.Top="140"
                       Foreground="white" FontSize="13"
                       FontFamily="{StaticResource PixelFont}"
                       Text="5 хв"/>

            <Slider x:Name="SliderAutoSave"
                    Canvas.Left="27" Canvas.Top="162"
                    Width="290" Height="22"
                    Minimum="1" Maximum="10"
                    Value="5"
                    SmallChange="1" LargeChange="1"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"
                    Cursor="Hand"
                    ValueChanged="SliderAutoSave_ValueChanged">
                <Slider.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Slider.Background>
            </Slider>

            <TextBlock Text="1 хв"
                       Canvas.Left="27" Canvas.Top="186"
                       Foreground="white" FontSize="11"
                       FontFamily="{StaticResource PixelFont}"/>

            <TextBlock Text="10 хв"
                       Canvas.Left="295" Canvas.Top="186"
                       Foreground="white" FontSize="11"
                       FontFamily="{StaticResource PixelFont}"/>

            <Button x:Name="BtnConfirm"
                    Width="140" Height="24"
                    Canvas.Left="27" Canvas.Top="454"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnConfirm_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <Button x:Name="BtnBack"
                    Width="141" Height="24"
                    Canvas.Left="182" Canvas.Top="454"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnBack_Click" HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <Slider x:Name="VolumeSlider" 
        Minimum="0" Maximum="1" 
        Value="0.5" 
        ValueChanged="VolumeSlider_ValueChanged" 
        Width="290" Canvas.Left="27" Canvas.Top="244" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <TextBlock Text="Гучність"
           Canvas.Left="27" Canvas.Top="230"
           Foreground="white" FontSize="13"
           FontFamily="{StaticResource PixelFont}"/>
        </Canvas>
    </Border>
</UserControl>