<UserControl x:Class="Dark_Horizon.Views.Battle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             RenderOptions.BitmapScalingMode="NearestNeighbor"
             Width="1920" Height="1080">

    <UserControl.Resources>
        <FontFamily x:Key="PF">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>

        <Style x:Key="BattleButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource PF}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="BtnGrid">
                            <Image x:Name="BtnImg" 
                                   Source="pack://application:,,,/Assets/Images/UI/Button.png"
                                   Stretch="Fill"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True"/>

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnImg" Property="Opacity" Value="0.88"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnImg" Property="Opacity" Value="0.6"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnGrid" Property="Opacity" Value="0.35"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="True">
                                <Setter TargetName="BtnGrid" Property="Opacity" Value="1.0"/>
                                <Setter Property="Foreground" Value="white"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Image x:Name="BattleBg"
               Source="pack://application:,,,/Assets/Images/Backgrounds/Forest.png"
               Stretch="UniformToFill" Opacity="0.6"/>
        <Rectangle Fill="#BB000000"/>

        <Grid VerticalAlignment="Top" Margin="140,30,140,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                    <Border Background="#333333" BorderBrush="#1F1F1F" BorderThickness="2" Padding="10,3" Margin="0,0,6,0">
                        <TextBlock x:Name="TxtPlayerLevel" Text="РВ 1" FontFamily="{StaticResource PF}" FontSize="17" Foreground="white"/>
                    </Border>
                    <TextBlock x:Name="TxtPlayerName" Text="Герой" FontFamily="{StaticResource PF}" FontSize="26" Foreground="white" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Width="560" Height="38" Background="#292929" BorderBrush="#1F1F1F" BorderThickness="2" HorizontalAlignment="Left">
                    <Grid>
                        <Rectangle x:Name="PlayerHpFill" Fill="#C0392B" HorizontalAlignment="Left" Width="556"/>
                        <TextBlock x:Name="TxtPlayerHp" FontFamily="{StaticResource PF}" FontSize="15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="VS" FontFamily="{StaticResource PF}" FontSize="34" Foreground="white" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="30,0,30,4"/>

            <StackPanel Grid.Column="2">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,6">
                    <TextBlock x:Name="TxtEnemyName" Text="Ворог" FontFamily="{StaticResource PF}" FontSize="26" Foreground="white" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <Border Background="#333333" BorderBrush="#1F1F1F" BorderThickness="2" Padding="10,3">
                        <TextBlock x:Name="TxtEnemyLevel" Text="РВ 1" FontFamily="{StaticResource PF}" FontSize="17" Foreground="white"/>
                    </Border>
                </StackPanel>

                <Border Width="560" Height="38" Background="#292929" BorderBrush="#1F1F1F" BorderThickness="2" HorizontalAlignment="Right">
                    <Grid>
                        <Rectangle x:Name="EnemyHpFill" Fill="#8B2020" HorizontalAlignment="Left" Width="556"/>
                        <TextBlock x:Name="TxtEnemyHp" FontFamily="{StaticResource PF}" FontSize="15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Margin="60,160,60,273">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="2" Width="860" Height="200" HorizontalAlignment="Center" VerticalAlignment="Top" Background="#333333" BorderBrush="#1F1F1F" BorderThickness="2">
                <ScrollViewer x:Name="LogScroll" Padding="14,8" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtLog" FontFamily="{StaticResource PF}" FontSize="17" Foreground="#EEE" TextWrapping="Wrap" Text="Бій починається!"/>
                </ScrollViewer>
            </Border>

            <Image Grid.Column="0" 
                   Source="pack://application:,,,/Assets/Images/Characters/WElf.png"
                   Width="240" Height="340" 
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                   Margin="100,0,0,-6"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <Image x:Name="EnemySprite" 
                   Grid.Column="1" 
                   Width="240" Height="340" 
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                   Margin="0,0,100,-6"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Grid>

        <Border VerticalAlignment="Bottom" Height="268" BorderBrush="Transparent" BorderThickness="0,2,0,0">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Images/UI/ActionPanel.png" TileMode="None" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border.Background>
            <Grid Margin="40,16,40,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TxtHint1" Grid.Row="0" Text="КУДИ БИТИ?" FontFamily="{StaticResource PF}" FontSize="19" Foreground="white" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <StackPanel x:Name="AttackPanel" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button x:Name="BtnAtkHead" Content="🎯  ГОЛОВА" Width="220" Height="50" FontSize="20" Style="{StaticResource BattleButtonStyle}" Click="AtkBtn_Click" Tag="Head"/>
                    <Button x:Name="BtnAtkChest" Content="🛡  ГРУДИ" Width="220" Height="50" FontSize="20" Style="{StaticResource BattleButtonStyle}" Click="AtkBtn_Click" Tag="Chest" Margin="8,0,0,0"/>
                    <Button x:Name="BtnAtkStomach" Content="💢  ЖИВІТ" Width="220" Height="50" FontSize="20" Style="{StaticResource BattleButtonStyle}" Click="AtkBtn_Click" Tag="Stomach" Margin="8,0,0,0"/>
                    <Button x:Name="BtnAtkLegs" Content="🦵  НОГИ" Width="220" Height="50" FontSize="20" Style="{StaticResource BattleButtonStyle}" Click="AtkBtn_Click" Tag="Legs" Margin="8,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="TxtHint2" Grid.Row="2" Text="ЩО ЗАХИСТИТИ?" FontFamily="{StaticResource PF}" FontSize="19" Foreground="white" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <StackPanel x:Name="DefendPanel" Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Button x:Name="BtnDefHead" Content="🎯  ГОЛОВА" Width="220" Height="50" FontSize="20" Style="{StaticResource BattleButtonStyle}" Click="DefBtn_Click" Tag="Head"/>
                    <Button x:Name="BtnDefChest" Content="🛡  ГРУДИ" Width="220" Height="50" FontSize="20" Style="{StaticResource BattleButtonStyle}" Click="DefBtn_Click" Tag="Chest" Margin="8,0,0,0"/>
                    <Button x:Name="BtnDefStomach" Content="💢  ЖИВІТ" Width="220" Height="50" FontSize="20" Style="{StaticResource BattleButtonStyle}" Click="DefBtn_Click" Tag="Stomach" Margin="8,0,0,0"/>
                    <Button x:Name="BtnDefLegs" Content="🦵  НОГИ" Width="220" Height="50" FontSize="20" Style="{StaticResource BattleButtonStyle}" Click="DefBtn_Click" Tag="Legs" Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnFight" Content="⚔  АТАКУВАТИ" Width="280" Height="52" FontSize="20" Style="{StaticResource BattleButtonStyle}" IsEnabled="False" Click="BtnFight_Click" Margin="0,0,16,0"/>
                    <Button x:Name="BtnInventory" Content="🎒  ІНВЕНТАР" Width="220" Height="52" FontSize="17" Style="{StaticResource BattleButtonStyle}" Click="BtnInventory_Click" Margin="0,0,16,0"/>
                    <Button x:Name="BtnFlee" Content="🏃  ВТЕКТИ" Width="220" Height="52" FontSize="17" Style="{StaticResource BattleButtonStyle}" Click="BtnFlee_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="InvOverlay" Background="#CC000000" Visibility="Collapsed">
            <Border Width="660" Height="580" Background="#292929" BorderBrush="#1F1F1F" BorderThickness="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ЇЖА ТА ЗІЛЛЯ" FontFamily="{StaticResource PF}" FontSize="24" Foreground="white" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="FoodList"/>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="ЗАКРИТИ" Width="200" Height="46" FontSize="17" Style="{StaticResource BattleButtonStyle}" HorizontalAlignment="Center" Margin="0,16,0,0" Click="BtnCloseInv_Click"/>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="EndOverlay" Background="#DD000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TxtEndTitle" FontFamily="{StaticResource PF}" FontSize="52" Foreground="white" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock x:Name="TxtEndDetails" FontFamily="{StaticResource PF}" FontSize="22" Foreground="#EEE" HorizontalAlignment="Center" Margin="0,0,0,32"/>
                <Button x:Name="BtnEndContinue" Content="ПРОДОВЖИТИ" Width="280" Height="58" FontSize="20" Style="{StaticResource BattleButtonStyle}" HorizontalAlignment="Center" Click="BtnEndContinue_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>