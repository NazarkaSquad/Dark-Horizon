<Window x:Class="Dark_Horizon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Dark_Horizon.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="1080" Width="1920" WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        WindowState="Maximized"
        Background="White"
        ResizeMode="NoResize">

    <Viewbox Stretch="Uniform">
		<Grid x:Name="MainGrid" Width="1920" Height="1080">
            
			<ContentControl x:Name="MainContentPresenter" />

			<Button x:Name="BtnMenu"
                    Width="80" Height="80"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnMenu_Click"
                    Visibility="Collapsed">
				<Button.Template>
					<ControlTemplate TargetType="Button">
						<Border Background="Transparent" BorderThickness="0">
							<ContentPresenter/>
						</Border>
					</ControlTemplate>
				</Button.Template>
				<Image Source="pack://application:,,,/Assets/Images/UI/MenuButton.png"
                        RenderOptions.BitmapScalingMode="NearestNeighbor"/>
			</Button>

			<Grid x:Name="PauseMenuOverlay" Visibility="Collapsed" Background="#AA000000">
				<Grid Width="350" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.Resources>
                        <FontFamily x:Key="PixelFont">pack://application:,,,/Assets/Fonts/#7:12 Serif Regular</FontFamily>
                    </Grid.Resources>

                    <Image Source="pack://application:,,,/Assets/Images/UI/Menu.png"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Stretch="Fill"/>

                    <StackPanel Margin="0,75,0,0" HorizontalAlignment="Center">
                        <StackPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>


                        <Button x:Name="BtnResume" Width="200" Height="40" Margin="0,0,0,42" BorderThickness="0" Cursor="Hand" Click="BtnResume_Click"/>

                        <Button x:Name="BtnInGameSettings" Width="200" Height="40" Margin="0,0,0,42" BorderThickness="0" Cursor="Hand" Click="BtnInGameSettings_Click"/>

                        <Button x:Name="BtnSaveGame" Width="200" Height="40" Margin="0,0,0,42" BorderThickness="0" Cursor="Hand" Click="BtnSaveGame_Click"/>

                        <Button x:Name="BtnInGameExit" Width="250" Height="42" Cursor="Hand" Click="BtnInGameExit_Click"/>

                        <TextBlock x:Name="TxtSaveFeedback"
                                   Text="ГРУ ЗБЕРЕЖЕНО!"
                                   FontFamily="{StaticResource PixelFont}"
                                   FontSize="14"
                                   Foreground="white"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"
                                   Visibility="Collapsed"/>
					</StackPanel>
				</Grid>
			</Grid>

			<Grid x:Name="InGameSettingsContainer" Visibility="Collapsed" Background="#AA000000">
                <Viewbox Width="525" Height="750" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <views:Settings x:Name="InGameSettingsView"/>
                </Viewbox>
            </Grid>

			<Grid x:Name="InventoryOverlayContainer" Visibility="Collapsed">
                <views:InventoryOverlay x:Name="InventoryOverlayView"/>
            </Grid>

			<Grid x:Name="TransitionOverlay" IsHitTestVisible="False" Background="Transparent">
				<Grid.RowDefinitions>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>
				<Rectangle x:Name="TopCurtain" Fill="Black" VerticalAlignment="Top" Height="0" Grid.Row="0" Grid.ColumnSpan="2"/>
				<Rectangle x:Name="BottomCurtain" Fill="Black" VerticalAlignment="Bottom" Height="0" Grid.Row="1" Grid.ColumnSpan="2"/>
				<Rectangle x:Name="LeftCurtain" Fill="Black" HorizontalAlignment="Left" Width="0" Grid.Column="0" Grid.RowSpan="2"/>
				<Rectangle x:Name="RightCurtain" Fill="Black" HorizontalAlignment="Right" Width="0" Grid.Column="1" Grid.RowSpan="2"/>
			</Grid>
		</Grid>
	</Viewbox>
</Window>